[node name="Tutorials" type="Node" parent="NavigationRegion3D/StaticBody3D/StartingRoom" unique_id=765198585]

[node name="Tuto1" type="Label3D" parent="NavigationRegion3D/StaticBody3D/StartingRoom/Tutorials" unique_id=263429856]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7.6875405, 1.8932433, 0.7897359)
modulate = Color(0.71, 0.71, 0.71, 1)
text = "¡Bienvenido al tutorial!
Usa WASD para moverte.
Hay una caja al sur de este
mensaje, ve allí."
font_size = 64
outline_size = 16

[node name="Tuto2" type="Label3D" parent="NavigationRegion3D/StaticBody3D/StartingRoom/Tutorials" unique_id=862980504]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7.0707655, 3.2508965, 8.117105)
text = "Por el mapa
habrán enemigos que
intentarán matarte.
"
font_size = 64
outline_size = 16

[node name="Tuto2-2" type="Label3D" parent="NavigationRegion3D/StaticBody3D/StartingRoom/Tutorials" unique_id=1744686980]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7.0228696, 1.5362061, 8.165896)
text = "¡Defíendete de esta caja!
Apúntala con el ratón y usa el click
izquierdo para atacarla.
Después, camina hacia la derecha."
font_size = 64
outline_size = 16

[node name="Tuto3" type="Label3D" parent="NavigationRegion3D/StaticBody3D/StartingRoom/Tutorials" unique_id=1646885481]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 5.0948544, 3.6723442, 8.434303)
text = "Te habrás dado cuenta de que tienes
un circulo en la esquina inferior derecha
de tu pantalla."
font_size = 64
outline_size = 16

[node name="Tuto3-2" type="Label3D" parent="NavigationRegion3D/StaticBody3D/StartingRoom/Tutorials" unique_id=1866424044]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 5.0948544, 1.7769105, 8.434303)
text = "¡Este es tu medidor de ataque especial!
Cuando esté suficientemente lleno, usa
el botón derecho del ratón para hacer
otro tipo de ataque."
font_size = 64
outline_size = 16

[node name="Tuto4" type="Label3D" parent="NavigationRegion3D/StaticBody3D/StartingRoom/Tutorials" unique_id=951026032]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 5.7957954, 1.7769105, 1.0099545)
modulate = Color(0.69, 0.69, 0.69, 1)
text = "Por último, al pulsar la barra espaciadora
te moverás rápidamente hacia una dirección.
Esto te vuelve invulnerable por unos instantes,
lo que te permite esquivar ataques enemigos.
Hay un enemigo más adelante, ¡inténtalo con él!"
font_size = 64
outline_size = 16

