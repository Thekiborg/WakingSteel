[node name="Tutorials" type="Node" parent="NavigationRegion3D/StaticBody3D/DiningRoom" unique_id=1842730744]

[node name="Tuto1-1" type="Label3D" parent="NavigationRegion3D/StaticBody3D/DiningRoom/Tutorials" unique_id=21312558]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3.6254673, 3.0719593, -28.437376)
modulate = Color(0.71, 0.71, 0.71, 1)
text = "No fue tan difícil, ¿verdad?
Por toda esta habitación vas a encontrar objetos.
Al acercarte, podrás agarrarlos usando la barra espaciadora.
"
font_size = 64
outline_size = 16

[node name="Tuto1-2" type="Label3D" parent="NavigationRegion3D/StaticBody3D/DiningRoom/Tutorials" unique_id=670087111]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3.82409, 1.0957716, -28.300978)
modulate = Color(0.71, 0.71, 0.71, 1)
text = "Puedes ver todos tus objetos en tu inventario,
lo puedes abrir pulsando la tecla TAB.
Haciendo click en un objeto puedes ver información,
y te saldrán algunas acciones que puedes usar con él.
"
font_size = 64
outline_size = 16

[node name="Tuto1-3" type="Label3D" parent="NavigationRegion3D/StaticBody3D/DiningRoom/Tutorials" unique_id=1075294284]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 16.554703, 1.7918427, -28.015411)
modulate = Color(0.71, 0.71, 0.71, 1)
text = "Esto es un objeto de curación.
Tu vida actual se puede comprobar pulsando
en el icono de la esquina inferior izquierda.
Cada parte de tu cuerpo tiene vida propia, y se 
pueden reparar pulsando click en las partes coloreadas,
y luego en el objeto de curación que quieras usar.
Ten cuidado, porque las partes completamente rotas (en gris)
no se pueden reparar.
"
font_size = 64
outline_size = 16

